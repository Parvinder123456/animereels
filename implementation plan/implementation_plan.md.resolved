### Camera Director Integration

#### [MODIFY] [cameraDirector.js](file:///c:/Users/parvi/Documents/animereels/server/services/cameraDirector.js)

Add format-aware dispatching:

```diff
+import { isWebtoonStrip, analyzeWebtoonStrip } from './webtoonCamera.js';
+import sharp from 'sharp';

 export async function detectFocusRegions(projectId, onProgress) {
   // ... existing cache check ...
   
   for (let i = 0; i < images.length; i++) {
     const imgPath = images[i];
+    const { width, height } = await sharp(imgPath).metadata();
+    
+    if (isWebtoonStrip(width, height)) {
+      // Webtoon path: interest points + scroll data
+      const scrollData = await analyzeWebtoonStrip(imgPath, imgFile);
+      focusMap[imgFile] = { 
+        regions: scrollData.interestPoints,
+        isWebtoon: true,
+        scrollPath: scrollData   // full scroll metadata
+      };
+    } else {
       // Existing manga path
       // ... current focus region detection ...
+    }
   }
 }
```

The `focusMap` entry gains an `isWebtoon: true` flag that the renderer checks.

