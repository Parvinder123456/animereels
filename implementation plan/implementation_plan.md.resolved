### Video Renderer Integration  

#### [MODIFY] [videoRenderer.js](file:///c:/Users/parvi/Documents/animereels/server/services/videoRenderer.js)

In the camera clip generation loop (lines 378-419), add webtoon branch:

```diff
+import { renderScrollClip } from './webtoonCamera.js';

 // Inside the camera clip loop:
 if (hasFocusData && pageFocus && pageExists) {
+  if (pageFocus.isWebtoon && pageFocus.scrollPath) {
+    // WEBTOON: continuous scroll clip
+    await renderScrollClip(
+      pagePath, 
+      pageFocus.scrollPath.interestPoints,
+      clipDuration, 
+      clipPath,
+      entry.mood
+    );
+  } else if (pageFocus.regions?.length > 0) {
     // MANGA: multi-shot clip (existing)
     await generateMultiShotClip(...);
+  }
 }
```

