### 4. Camera Director — Format-Aware Dispatch

#### [MODIFY] [cameraDirector.js](file:///c:/Users/parvi/Documents/animereels/server/services/cameraDirector.js)

Add a `format` parameter. When `format === 'webtoon'`, use the webtoon analysis instead of focus region detection:

```diff
-export async function detectFocusRegions(projectId, onProgress) {
+export async function detectFocusRegions(projectId, onProgress, format = 'manga') {

   for (let i = 0; i < images.length; i++) {
+    if (format === 'webtoon') {
+      const scrollData = await analyzeWebtoonStrip(imgPath);
+      focusMap[imgFile] = {
+        regions: scrollData.interestPoints,
+        isWebtoon: true,
+        scrollPath: scrollData,
+      };
+    } else {
       // existing manga focus region detection
+    }
   }
```

---

### 5. Video Renderer — Scroll Clip Branch  

#### [MODIFY] [videoRenderer.js](file:///c:/Users/parvi/Documents/animereels/server/services/videoRenderer.js)

**Two changes:**

1. Pass `format` from `renderConfig` into `detectFocusRegions()`:
```diff
- focusRegions = await detectFocusRegions(projectId, ...);
+ const format = renderConfig.format || 'manga';
+ focusRegions = await detectFocusRegions(projectId, ..., format);
```

2. In the camera clip loop, add webtoon branch:
```diff
+import { renderScrollClip } from './webtoonCamera.js';

 if (hasFocusData && pageFocus && pageExists) {
+  if (pageFocus.isWebtoon && pageFocus.scrollPath) {
+    await renderScrollClip(pagePath, pageFocus.scrollPath, clipDuration, clipPath, entry.mood);
+  } else if (pageFocus.regions?.length > 0) {
     await generateMultiShotClip(...);  // existing manga path
+  }
 }
```

---

### 6. Panel Splitter — Webtoon Mode

#### [MODIFY] [panelSplitter.js](file:///c:/Users/parvi/Documents/animereels/server/services/panelSplitter.js)

For webtoon format, keep each page as a single unit (no gutter splitting):

```diff
-export async function splitAllChapters(projectId, onProgress) {
+export async function splitAllChapters(projectId, onProgress, format = 'manga') {

   for (let i = 0; i < images.length; i++) {
-    const { panels, width, height } = await detectPanels(imgPath);
+    let result;
+    if (format === 'webtoon') {
+      const { width, height } = await sharp(imgPath).metadata();
+      result = { panels: [{ x: 0, y: 0, w: width, h: height }], width, height };
+    } else {
+      result = await detectPanels(imgPath);
+    }
+    const { panels, width, height } = result;
```

This means timeline builder gets **1 panel per page** for webtoon → longer duration per entry → enough time for a meaningful scroll-through (~4-5s per page for a 67-page chapter at 5 min).

---

### 7. Upload Route — Pass Format to Splitter

#### [MODIFY] [upload.js](file:///c:/Users/parvi/Documents/animereels/server/routes/upload.js) 

Read `project.config.format` and pass it to `splitAllChapters()`.

#### [MODIFY] [panels.js](file:///c:/Users/parvi/Documents/animereels/server/routes/panels.js)

Same — pass format to both `splitAllChapters()` and `detectAllPanels()`.

